# ========================================
# FLATUP AIKA LINE BOT 環境変数設定
# ========================================
# このファイルをコピーして /root/flatup_config.env として使用してください

# LINE Messaging API 認証情報
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_ACCESS_TOKEN=your_access_token_here
LINE_BOT_USER_ID=U521cd38b7f048be84eaa880ccabdc7f9

# OpenRouter API キー
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# AIKA 人格ファイルパス
AIKA_PROMPT_PATH=/root/flatup_brain/1_AIKA人格_本番.md

# 環境変数ファイルのパス（デフォルト: /root/flatup_config.env）
FLATUP_CONFIG_PATH=/root/flatup_config.env
